#lang sicp
#|Exercise 1.3: Define a procedure that takes three numbers
as arguments and returns the sum of the squares of the two
larger numbers.|#

;sq means square
(define (sq x)
  (* x x))

;sos means sum of squares
(define (sos x y)
  (+ (sq x) (sq y)))

;sos2ln means sum of square of two large numbers

(define (sos2ln a b c)
  (cond ((and (>= a b) (>= b c))
         (sos a b))
        ((and (>= b c) (>= c a))
         (sos b c))
        ((and (>= a b) (>= c b))
         (sos a c))))

(sos2ln 4 5 3)
(sos2ln 3 4 5)